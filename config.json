{
    "paths": {
        "video_folders": ["./my_drone_videos"],
                          
        "music_folders": ["./music"],
        "db_folder": "./chroma_db",
        "temp_render_dir": "./temp_render",
        "lut_file": "dji.cube",
        "log_file": "logs/drone_editor.log"
    },
    "system_performance": {
        "num_workers": 4,
        "batch_size": 16,
        "queue_max_size": 150
    },
    "ai_settings": {
        "model_id": "openai/clip-vit-base-patch32",
        "collection_name": "drone_footage",
        "search_top_k": 5,
        "model_dir": "./models/"
    },
    "montage_timing": {
        "sync_to_beats": true,
        "clip_duration": 4.0,
        "fade_duration": 1.0,
        "num_clips_to_generate": 20
    },
    "intelligence_filters": {
        "fps_to_extract": 15,
        "min_gap_seconds": 10.0,
        "max_similarity_score": 0.65,
        "max_motion_variance": 7.5
    }
}